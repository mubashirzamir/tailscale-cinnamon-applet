{
    "uuid": "tailscale@mubashirzamir",
    "_name": "Tailscale Control",
    "_description": "Toggle Tailscale from the Cinnamon panel.",
    "schema_version": 1,
    "settings": [
        {
            "type": "spinbutton",
            "name": "poll_interval",
            "_name": "Poll interval",
            "_description": "Seconds between Tailscale state refreshes.",
            "_default": 60,
            "min": 10,
            "max": 120,
            "step": 5
        },
        {
            "type": "entry",
            "name": "preferred_exit_node",
            "_name": "Preferred exit node",
            "_description": "Tailscale exit node hostname. Leave empty for none.",
            "_default": ""
        },
        {
            "type": "switch",
            "name": "auto_connect_on_load",
            "_name": "Auto-connect on load",
            "_description": "Run tailscale up when the applet starts.",
            "_default": false
        }
    ]
}
